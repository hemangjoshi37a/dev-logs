{
  "name": "@hemangjoshi37a/dev-logs",
  "version": "1.0.0",
  "description": "AI-centric dev submission and tracking platform — capture bugs, features, and improvements with rich context",
  "type": "module",
  "bin": {
    "dev-logs": "./bin/dev-logs.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server && npm run build:overlay",
    "build:client": "vite build --outDir dist/client",
    "build:server": "tsx server/build.ts",
    "build:overlay": "vite build --config vite.overlay.config.ts",
    "preview": "vite preview",
    "start": "node bin/dev-logs.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dev-tools",
    "bug-tracking",
    "bug-report",
    "screenshot-capture",
    "developer-tools",
    "issue-tracker",
    "floating-widget",
    "ai-ready",
    "context-capture",
    "console-logs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hemangjoshi37a/dev-logs.git"
  },
  "homepage": "https://github.com/hemangjoshi37a/dev-logs",
  "bugs": {
    "url": "https://github.com/hemangjoshi37a/dev-logs/issues"
  },
  "author": "Hemang Joshi <hemangjoshi37a@gmail.com> (https://hjlabs.in)",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.95.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  }
}
